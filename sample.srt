// lib/agents.js
import { HumanMessage, AIMessage, SystemMessage } from '@langchain/core/messages';
import { StateGraph, START, END } from '@langchain/langgraph/web';
import { ChatAnthropic } from '@langchain/anthropic';
import { StructuredTool } from '@langchain/core/tools'; // Import StructuredTool

/* ------------------------------------------------------------------ */
/* 1. Google Ads Tool                                                 */
/* ------------------------------------------------------------------ */
// ... (your existing GoogleAdsCreatorTool class definition)

/* ------------------------------------------------------------------ */
/* 2. LangGraph definition                                            */
/* ------------------------------------------------------------------ */
const SYSTEM_PROMPT = `
You are AdMaster Pro, an expert Google Ads assistant.
Do NOT create a campaign unless the user explicitly asks and provides:
- Campaign name
- Channel type (SEARCH, DISPLAY, VIDEO, or SHOPPING)
- Budget (optional, defaults to $10)
- Start/end dates (optional)
- Ad headlines & descriptions (if SEARCH)

If any required info is missing, ask the user before proceeding.
`;

export function createGoogleAdsCreatorAgent() {
  const toolInstance = new GoogleAdsCreatorTool(); // Create an instance of your tool

  // Create a StructuredTool from your tool instance
  const googleAdsTool = new StructuredTool({
    name: toolInstance.name,
    description: toolInstance.description,
    schema: toolInstance.schema.parameters, // Pass the parameters section of your schema
    func: async (args) => toolInstance._call(args), // Bind the _call method to the tool's func
  });

  const llm = new ChatAnthropic({
   modelName: 'claude-3-haiku-20240307',
  temperature: 0.3,
  maxTokens: 1000,
  apiKey: process.env.NEXT_PUBLIC_ANTHROPIC_API_KEY || '',
  }).bindTools([googleAdsTool]); // Pass the StructuredTool instance here
 
  /* ---------------- State machine ---------------- */
  const graph = new StateGraph({
    channels: {
      messages: { default: () => [] },
    },
  })
    .addNode('llm', async (state, config) => {
      // inject ctx into tool
      toolInstance.ctx = config.configurable; // Use toolInstance here
      const msgs = state.messages;
      const result = await llm.invoke(msgs);
      return { messages: [...msgs, result] };
    })
    .addNode('tools', async (state) => {
      const last = state.messages[state.messages.length - 1];
      const toolCalls = last.tool_calls || [];
      const outputs = [];

      for (const call of toolCalls) {
        try {
          const res = await toolInstance._call(call.args); // Use toolInstance here
          outputs.push(
            new AIMessage({
              content: res.message,
              tool_call_id: call.id,
              name: toolInstance.name, // Use toolInstance here
            })
          );
        } catch (err) {
          outputs.push(
            new AIMessage({
              content: `❌ Error: ${err.message}`,
              tool_call_id: call.id,
              name: toolInstance.name, // Use toolInstance here
            })
          );
        }
      }
      return { messages: [...state.messages, ...outputs] };
    })
    .addEdge(START, 'llm')
    .addConditionalEdges('llm', (state) =>
      state.messages[state.messages.length - 1].tool_calls ? 'tools' : END
    )
    .addEdge('tools', 'llm');

  const runnable = graph.compile();

  /* ------------------------------------------------------------------ */
  /* 3. Streaming wrapper                                               */
  /* ------------------------------------------------------------------ */
  return {
    async chat(message, ctx) {
      const encoder = new TextEncoder();
      const stream = new TransformStream();
      const writer = stream.writable.getWriter();

      (async () => {
        const send = (type, data = {}) =>
          writer.write(
            encoder.encode(`data: ${JSON.stringify({ type, ...data })}\n\n`)
          );

        try {
          const messages = [
            new SystemMessage(SYSTEM_PROMPT),
            new HumanMessage(message),
          ];

          const finalState = await runnable.invoke(
            { messages },
            { configurable: ctx }
          );

          // stream out every assistant message
          for (const m of finalState.messages) {
            if (m._getType() === 'ai') {
              await send('content', { content: m.content });
            }
          }
          await send('end');
        } catch (err) {
          console.error(err);
          await send('error', { message: err.message });
        } finally {
          await writer.close();
        }
      })();

      return stream.readable;
    },
  };
}




